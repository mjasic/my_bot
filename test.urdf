  <!-- ===================== -->
  <joint name="camera_joint" type="fixed">
    <parent link="chassis"/>
    <child link="camera_link"/>
    <origin rpy="0 0 0" xyz="0.305 0 0.08"/>
  </joint>
  <!-- ===================== -->
